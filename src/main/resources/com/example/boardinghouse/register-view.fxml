<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.boardinghouse.RegisterController">
   <children>
      <GridPane layoutX="51.0" layoutY="47.0" prefHeight="292.0" prefWidth="498.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Create an account" GridPane.valignment="TOP">
               <font>
                  <Font size="29.0" />
               </font>
            </Label>
            <Label text="Username" GridPane.halignment="LEFT" GridPane.valignment="BOTTOM">
               <font>
                  <Font size="22.0" />
               </font>
               <GridPane.margin>
                  <Insets />
               </GridPane.margin>
            </Label>
            <TextField fx:id="tfUsername" GridPane.columnIndex="1" GridPane.valignment="BOTTOM" />
            <Label text="Password" GridPane.rowIndex="1">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <PasswordField fx:id="pfPassword" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Occupation" GridPane.rowIndex="2">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <ComboBox fx:id="cbRole" prefHeight="25.0" prefWidth="105.0" GridPane.columnIndex="1" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <Hyperlink fx:id="hlLogin" layoutX="51.0" layoutY="328.0" onAction="#onGoToLoginClicked" text="Back to login" />
   </children>
</AnchorPane>

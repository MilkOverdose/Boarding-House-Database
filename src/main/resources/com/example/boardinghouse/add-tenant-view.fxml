<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.boardinghouse.AddTenantController">
    <padding>
        <Insets top="30" bottom="30" left="40" right="40"/>
    </padding>

    <Label text="Add Tenant" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="tfName" promptText="Full Name"/>
    <TextField fx:id="tfAge" promptText="Age"/>
    <TextField fx:id="tfContact" promptText="Contact Number"/>
    <TextField fx:id="tfRoomNum" promptText="Room Number"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Add Tenant" onAction="#onAddTenantClicked"/>
        <Button text="Back" onAction="#onBackClicked"/>
    </HBox>

    <Label fx:id="lblMessage" style="-fx-text-fill: red;"/>

</VBox>